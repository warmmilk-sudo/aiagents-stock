+            authed_at = int(st.session_state.get("authenticated_at", 0))
+            ttl = max(getattr(config, "ADMIN_SESSION_TTL_SECONDS", 28800), 60)
+            if authed_at <= 0 or int(time.time()) - authed_at > ttl:
