# AI股票分析系统环境配置模板
# 复制为 .env 后按实际情况填写；敏感信息不要提交到版本控制

# ========== DeepSeek / OpenAI兼容 API 配置 ==========
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 
SMART_MONITOR_HTTP_TIMEOUT_SECONDS=30
SMART_MONITOR_HTTP_RETRY_COUNT=1
SMART_MONITOR_AI_TIMEOUT_SECONDS=70
SMART_MONITOR_REASONING_MAX_TOKENS=3000

# 默认模型名
LIGHTWEIGHT_MODEL_NAME=deepseek-chat
REASONING_MODEL_NAME=deepseek-reasoner

# 侧边栏下拉候选，逗号分隔；留空时只显示当前默认模型
LIGHTWEIGHT_MODEL_OPTIONS=deepseek-chat,qwen-plus
REASONING_MODEL_OPTIONS=deepseek-reasoner,deepseek-chat

# ========== 管理员与登录 ==========
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
ADMIN_SESSION_TTL_SECONDS=28800

# ========== 网站备案 ==========
ICP_NUMBER=
ICP_LINK=

# ========== Tushare ==========
TUSHARE_TOKEN=
TUSHARE_URL=https://api.tushare.pro

# ========== TDX数据接口（可选）==========
TDX_ENABLED=false
TDX_BASE_URL=http://127.0.0.1:8181

# ========== 全局分析与数据源 ==========
DATA_PERIOD=1y
RISK_QUERY_TIMEOUT_SECONDS=10
TZ=Asia/Shanghai

# ========== 智能盯盘默认间隔 ==========
SMART_MONITOR_AI_INTERVAL_MINUTES=60
SMART_MONITOR_PRICE_ALERT_INTERVAL_MINUTES=3

# ========== 邮件通知 ==========
EMAIL_ENABLED=false
SMTP_SERVER=smtp.163.com
SMTP_PORT=465
EMAIL_FROM=your_email@163.com
EMAIL_PASSWORD=your_email_authorization_code
EMAIL_TO=receiver@example.com

# ========== Webhook 通知 ==========
WEBHOOK_ENABLED=false
WEBHOOK_TYPE=dingtalk
WEBHOOK_URL=
WEBHOOK_KEYWORD=
